# DSPy Guardrails Environment Configuration
# Copy this file to .env and fill in your values

# --- LLM Providers (at least one required for LLM-based detection) ---

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenRouter (optional — access 100+ models via unified API)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Moonshot / Kimi (optional)
MOONSHOT_API_KEY=your-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k
